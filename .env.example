# Anthropic API Key
# Get yours at: https://console.anthropic.com -> API Keys -> Create Key
ANTHROPIC_API_KEY=your-key-here

# Brave Search API Key (optional - enables live web research in Pipeline Mode)
# Get a free key at: https://brave.com/search/api/ (2000 queries/month free)
# BRAVE_SEARCH_API_KEY=your-brave-key-here

# Auth (Magic Link Login)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here
# Get yours at: https://resend.com -> API Keys
RESEND_API_KEY=re_xxxxxxxxxx
# App URL (used in magic link emails)
NEXT_PUBLIC_APP_URL=https://aacm.vercel.app

# Database (Vercel Postgres)
# Provision via Vercel Dashboard → Storage → Create Database → Postgres
DATABASE_URL=postgres://...
